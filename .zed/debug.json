[
	{
		"label": "Debug native binary",
		"build": {
			"command": "make",
			"args": [
				"tls",
				"-B",
				"O_DEBUG=1"
			],
			"cwd": "$ZED_WORKTREE_ROOT",
			"shell": {
				"with_arguments": {
					"program": "/bin/sh",
					"args": []
				}
			}
		},
		"program": "$ZED_WORKTREE_ROOT/local-mark",
		"args": [
			"--log-level",
			"debug",
			"--log-file",
			"build/debug.log",
			"bookmarks.json"
		],
		"request": "launch",
		"adapter": "CodeLLDB"
	}
]
